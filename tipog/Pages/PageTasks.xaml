<Page x:Class="tipog.Pages.PageTasks"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:tipog.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageTasks">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Фоновое изображение -->
        <Image Margin="0,-19,-142,-11" Grid.RowSpan="3" Source="/Images/загрузка.png" Stretch="Fill"/>

        <!-- Верхняя панель: Фильтры и поиск -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0">
            <ComboBox x:Name="ComboFilter" VerticalAlignment="Center" Width="209" SelectionChanged="ComboFilter_SelectionChanged" Height="26" Margin="5">
                <ComboBox.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFDAEBFF"/>
                        <GradientStop Color="#FFDAEBFF" Offset="1"/>
                    </LinearGradientBrush>
                </ComboBox.Background>
            </ComboBox>
            <ComboBox x:Name="ComboSort" VerticalAlignment="Center" Width="198" SelectionChanged="ComboSort_SelectionChanged" Height="26" Margin="5">
                <ComboBox.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFDAEBFF"/>
                        <GradientStop Color="#FFDAEBFF" Offset="1"/>
                    </LinearGradientBrush>
                </ComboBox.Background>
            </ComboBox>
            <TextBox x:Name="TextSearch" TextWrapping="Wrap" VerticalAlignment="Center" Width="186" TextChanged="TextSearch_TextChanged" Height="26" Margin="5"/>
        </StackPanel>

        <!-- Список продукции -->
        <ListView x:Name="ListProducts" Margin="0,26,0,55" Grid.RowSpan="2" MouseDoubleClick="ListProducts_MouseDoubleClick" SelectionChanged="ListProducts_SelectionChanged_1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#FFDAEBFF" BorderThickness="1" Margin="5" Padding="15" Background="White" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <!-- Изображение -->
                            <Border Grid.Column="0" Width="220" Height="220" Margin="0" ClipToBounds="True" CornerRadius="5" Background="#FFF5F5F5">
                                <Image Source="{Binding imageProduct}" Stretch="UniformToFill"/>
                            </Border>

                            <!-- Информация -->
                            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0">
                                <TextBlock Text="{Binding name}" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,3" FontSize="14">
                            <Run Text="Тип продукции: " FontWeight="SemiBold" Foreground="#FF5B9BD5"/>
                            <Run Text="{Binding type_products.name}"/>
                                </TextBlock>
                                <TextBlock Margin="0,3" FontSize="14">
                            <Run Text="Цена: " FontWeight="SemiBold" Foreground="#FF5B9BD5"/>
                            <Run Text="{Binding price}"/>
                            <Run Text=" руб."/>
                                </TextBlock>
                                <TextBlock Margin="0,3" FontSize="14">
                            <Run Text="Материал: " FontWeight="SemiBold" Foreground="#FF5B9BD5"/>
                            <Run Text="{Binding materials.name}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Кнопка Корзина по центру вертикально -->
                            <Button Grid.Column="2" 
                            Width="50" 
                            Height="50" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#FF5B9BD5"
                            BorderThickness="0"
                            Click="ButtonCart_Click"
                            Tag="{Binding}"
                            ToolTip="Добавить в корзину"
                            Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF2E75B6"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Path Data="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z" 
                              Fill="White" 
                              Stretch="Uniform"
                              Width="24"
                              Height="24"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Нижняя панель с кнопками -->
        <Grid Grid.Row="2" Background="#FFF5F5F5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="121.87"/>
                <ColumnDefinition Width="58.13"/>
                <ColumnDefinition Width="45.052"/>
                <ColumnDefinition Width="99.658"/>
                <ColumnDefinition Width="35.29"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <!-- Счетчик -->
            <TextBlock x:Name="tbCounter" 
                       Grid.Column="0" 
                       Text="Найдено 0 продукции" 
                       VerticalAlignment="Top" 
                       Margin="30,-2,10,0"
                       FontSize="14"/>

            <!-- Кнопка 🧙 Помощник (ЯРКАЯ И ЗАМЕТНАЯ!) -->
            <Button Grid.Column="1" 
                    Content="🧙 Помощник ИИ" 
                    Height="45" 
                    Margin="0,-26,10,7"
                    Background="#FF5B9BD5"
                    Foreground="White"
                    FontSize="14"
                    BorderBrush="#FF2E75B6"
                    BorderThickness="2"
                    Click="ButtonHelper_Click"
                    Cursor="Hand" Grid.ColumnSpan="2">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF2E75B6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Кнопка Корзина -->
            <Button x:Name="btnOrder" 
                    Grid.Column="3" 
                    Content="🛒 Корзина" 
                    Height="45" 
                    Margin="0,-26,10,7"
                    Background="#FFDAEBFF"
                    Foreground="Black"
                    FontSize="14"
                    BorderBrush="#FF5B9BD5"
                    BorderThickness="1"
                    Click="Button_Click_1"
                    Cursor="Hand" Grid.ColumnSpan="3">
                <Button.ToolTip>
                    <ToolTip x:Name="ttCartCount" Content="0 товаров в корзине"/>
                </Button.ToolTip>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF5B9BD5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Кнопка Добавить -->
            <Button Grid.Column="6" 
                    Content="➕ Добавить" 
                    Height="45" 
                    Margin="0,-26,10,7"
                    Background="#FFDAEBFF"
                    Foreground="Black"
                    FontSize="14"
                    BorderBrush="#FF5B9BD5"
                    BorderThickness="1"
                    Click="Button_Click"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF5B9BD5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Декоративный цветок -->
    </Grid>
</Page>