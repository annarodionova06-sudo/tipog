<Page x:Class="tipog.Pages.PageQRCode"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:tipog.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageQRCode">

    <Grid>
        <Image Margin="-9,-25,-29,-9" Source="/Images/загрузка.png" Stretch="Fill"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-25,0,0" Height="476">
            <TextBlock Text="QR-код заказа" FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <Image x:Name="imgQr" Width="300" Height="300" Margin="10"/>
            <TextBlock x:Name="tbOrderNumber" Text="" FontSize="16" 
                       HorizontalAlignment="Center" Margin="0,10,0,20"/>
            <Button Content="Назад к списку" Width="150" Height="35" 
                    Click="ButtonBack_Click" Background="#FFDAEBFF"/>
        </StackPanel>
    </Grid>
</Page>
