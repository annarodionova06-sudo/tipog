<Page x:Class="tipog.Pages.PageQRCode"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:tipog.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageQRCode">

    <Grid>
        <!-- Фоновое изображение -->
        <Image Source="/Images/загрузка.png" Stretch="Fill"/>

        <!-- Основной контейнер -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
           
                <TextBlock Text="📱 QR-код заказа" 
                           Foreground="Black" 
                           FontSize="24" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
          

            <!-- QR-код по центру -->
            <Border Grid.Row="1" 
                    Background="White" 
                    CornerRadius="10" 
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#FF5B9BD5"
                    BorderThickness="2" Height="378">
                <StackPanel HorizontalAlignment="Center">
                    <Image x:Name="imgQr" 
                           Width="300" 
                           Height="331" 
                           Margin="10"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="tbOrderNumber" 
                               Text="" 
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" 
                               Margin="0,15,0,10"
                               Foreground="#FF5B9BD5"/>
                    <TextBlock Text="Отсканируйте для просмотра деталей" 
                               FontSize="12"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               Foreground="Gray"
                               Margin="0,0,0,10"/>
                </StackPanel>
            </Border>

            <!-- Кнопка Назад -->
            <Border Grid.Row="2" Padding="10" Margin="10">
                <Button Content="⬅️ Назад к списку" 
                        Width="200" 
                        Height="45"
                        HorizontalAlignment="Center"
                        Background="#FFDAEBFF"
                        Foreground="Black"
                        FontSize="14"
                        FontWeight="SemiBold"
                        BorderBrush="#FF5B9BD5"
                        BorderThickness="1"
                        Click="ButtonBack_Click"
                        Cursor="Hand" Margin="0,10,0,-10">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF5B9BD5"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Grid>
</Page>