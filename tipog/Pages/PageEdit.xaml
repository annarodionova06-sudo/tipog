<Page x:Class="tipog.Pages.PageEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:tipog.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageEdit">

    <Grid>
        <Image Margin="0,0,-11,0" Source="/Images/загрузка.png" Stretch="Fill"/>
        <TextBlock HorizontalAlignment="Left" Margin="346,82,0,0" TextWrapping="Wrap" Text="Название продукции:" VerticalAlignment="Top" FontSize="16"/>
        <TextBox HorizontalAlignment="Left" Margin="346,110,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="159" Height="21" TextChanged="TextBox_TextChanged" Text="{Binding name}"/>
        <TextBlock HorizontalAlignment="Left" Margin="584,82,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16"><Run Language="ru-ru" Text="Количество"/><Run Text=":"/></TextBlock>
        <TextBox HorizontalAlignment="Left" Margin="584,110,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="159" Height="21" TextChanged="TextBox_TextChanged" Text="{Binding count}"/>
        <ComboBox x:Name="cmbTypeProd" HorizontalAlignment="Left" Margin="346,179,0,0" VerticalAlignment="Top" Width="162" Height="25" SelectedIndex="{Binding id_type_products}"/>
        <TextBlock HorizontalAlignment="Left" Margin="346,145,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16"><Run Language="ru-ru" Text="Тип продукции:"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="584,145,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16"><Run Language="ru-ru" Text="Материал"/><Run Text=":"/></TextBlock>
        <ComboBox x:Name="cmbMaterial" HorizontalAlignment="Left" Margin="584,179,0,0" VerticalAlignment="Top" Width="162" Height="25" SelectedIndex="{Binding id_materials}"/>
        <TextBlock HorizontalAlignment="Left" Margin="584,225,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16"><Run Language="ru-ru" Text="Стоимость"/><Run Text=":"/></TextBlock>
        <TextBox HorizontalAlignment="Left" Margin="584,254,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="159" Height="21" TextChanged="TextBox_TextChanged" Text="{Binding price}"/>
        <TextBlock HorizontalAlignment="Left" Margin="346,225,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16"><Run Language="ru-ru" Text="Изображение"/><Run Text=":"/></TextBlock>
        <TextBox x:Name="txtImagePath" HorizontalAlignment="Left" Margin="346,254,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="159" Height="21" TextChanged="TextBox_TextChanged" Text="{Binding image}"/>
        <Image x:Name="imgProduct" HorizontalAlignment="Left" Height="243" Margin="46,82,0,0" VerticalAlignment="Top" Width="254" Source="{Binding imageProduct}"/>
        <Button Content="Загрузить изображение" HorizontalAlignment="Left" Margin="346,298,0,0" VerticalAlignment="Top" Height="38" Width="143" Background="#FFDAEBFF" Click="Button_Click_2"/>
        <Button Content="Сохранить продукцию" HorizontalAlignment="Left" Margin="584,298,0,0" VerticalAlignment="Top" Height="38" Width="143" Background="#FFDAEBFF" Click="Button_Click_1"/>
        <Button Content="Удалить продукцию" HorizontalAlignment="Left" Margin="584,348,0,0" VerticalAlignment="Top" Height="38" Width="143" Background="#FFDAEBFF" Click="Button_Click"/>
        <Image Margin="693,0,-11,340" Source="/Images/цветок-Photoroom.png" Stretch="Fill" RenderTransformOrigin="0.271,0.327"/>
        <Button x:Name="btnA" Content="Назад" HorizontalAlignment="Left" Margin="346,348,0,0" VerticalAlignment="Top" Height="38" Width="143" Background="#FFDAEBFF" Click="btnA_Click"/>
    </Grid>
</Page>
