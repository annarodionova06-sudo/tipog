<Page x:Class="tipog.Pages.PageOrder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:tipog.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageOrder">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Фон -->
        <Image Margin="0,-19,-142,-11" Grid.RowSpan="3" Source="/Images/загрузка.png" Stretch="Fill"/>

        <!-- Заголовок -->
        <TextBlock Text="Корзина" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center" 
                   FontSize="22"
                   Grid.Row="0"/>

        <!-- Список корзины -->
        <ListView x:Name="ListCart" Margin="26,7,-26,50" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#FFDAEBFF" BorderThickness="1" Margin="5" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- Изображение -->
                            <Border Width="150" Height="150" Margin="3" ClipToBounds="True" Grid.Column="0">
                                <Image Source="{Binding products.imageProduct}" Stretch="UniformToFill"/>
                            </Border>

                            <!-- Информация о продукте -->
                            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="{Binding products.name}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Margin="0,5,0,0">
                            <Run Text="Цена: "/>
                            <Run Text="{Binding products.price}"/>
                            <Run Text=" руб."/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Кнопки управления -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="-" Width="30" Height="30" Background="#FFDAEBFF" Click="ButtonMinus_Click" Tag="{Binding}"/>
                                <TextBlock Text="{Binding quantity}" Width="30" TextAlignment="Center" VerticalAlignment="Center" FontSize="16" Margin="5,0"/>
                                <Button Content="+" Width="30" Height="30" Background="#FFDAEBFF" Click="ButtonPlus_Click" Tag="{Binding}"/>
                                <Button Content="Удалить" Width="80" Height="30" Background="#FFFFB6C1" Margin="10,0,0,0" Click="ButtonDelete_Click" Tag="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Нижняя панель -->
        <TextBlock x:Name="tbTotal" 
                   HorizontalAlignment="Left" 
                   Margin="50,334,0,0" 
                   Grid.Row="1" 
                   TextWrapping="Wrap" 
                   VerticalAlignment="Top" 
                   Height="34" 
                   Width="250"
                   FontSize="16"
                   FontWeight="Bold"/>

        <Button Content="Оформить заказ" 
                HorizontalAlignment="Left" 
                Margin="350,321,0,0" 
                Grid.Row="1" 
                VerticalAlignment="Top" 
                Height="42" 
                Width="151" 
                Background="#FF90EE90"
                Click="ButtonOrder_Click"/>

        <Button Content="Назад" 
                HorizontalAlignment="Left" 
                Margin="520,321,0,0" 
                Grid.Row="1" 
                VerticalAlignment="Top" 
                Height="42" 
                Width="151" 
                Background="#FFDAEBFF"
                Click="ButtonBack_Click"/>
        <Button Content="Скачать чек"
        Background="#FF90EE90"
        Click="ButtonPrintReceipt_Click" Margin="184,322,465,35" Grid.Row="1"/>
    </Grid>
</Page>
