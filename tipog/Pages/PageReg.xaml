<Page x:Class="tipog.Pages.PageReg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:tipog.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageReg">

    <Grid>
        <Image Margin="0,0,-19,0" Source="/Images/загрузка.png" Stretch="Fill"/>
        <TextBlock HorizontalAlignment="Left" Margin="174,34,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="61" Width="512" FontSize="22"><Run Text="Регистрация"/><Run Text=" "/><Run Text="в Типографию &quot;Мастер печати&quot;"/></TextBlock>
        <Image Margin="643,302,2,-12" Source="/Images/цветок-Photoroom.png" Stretch="Fill" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="39.201"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <TextBlock HorizontalAlignment="Left" Margin="50,111,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="31" Width="178" FontSize="20"><Run Language="ru-ru" Text="Введите имя:"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="50,187,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="31" Width="178" FontSize="20"><Run Text="Введите"/><Run Language="ru-ru" Text=" логин"/><Run Text=":"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="50,275,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="31" Width="178" FontSize="20"><Run Text="Введите "/><Run Language="ru-ru" Text="пароль"/><Run Text=":"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="50,350,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="30" Width="256" FontSize="20"><Run Text="Введите "/><Run Text="пароль"/><Run Language="ru-ru" Text=" повторно"/><Run Text=":"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="328,111,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="30" Width="238" FontSize="20"><Run Text="Введите "/><Run Language="ru-ru" Text="дату рождения"/><Run Text=":"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="328,201,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="30" Width="238" FontSize="20"><Run Text="Введите"/><Run Language="ru-ru" Text=" почту:"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="330,284,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="30" Width="238" FontSize="20"><Run Text="Введите"/><Run Text=" "/><Run Language="ru-ru" Text="телефон"/><Run Text=":"/></TextBlock>
        <Button x:Name="btnReg" Content="Зарегистрироваться" HorizontalAlignment="Left" Margin="589,171,0,0" VerticalAlignment="Top" Height="44" Width="151" Background="#FFDAEBFF" Click="btnReg_Click"/>
        <Button x:Name="btnAgo" Content="Назад" HorizontalAlignment="Left" Margin="589,248,0,0" VerticalAlignment="Top" Height="44" Width="151" Background="#FFDAEBFF" Click="btnAgo_Click"/>
        <TextBox x:Name="txtName" HorizontalAlignment="Left" Margin="50,147,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="160" Height="30"/>
        <TextBox x:Name="txtLogin" HorizontalAlignment="Left" Margin="50,223,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="160" Height="30"/>
        <TextBox x:Name="txtEmail" HorizontalAlignment="Left" Margin="330,240,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="160" Height="30"/>
        <DatePicker x:Name="dB" HorizontalAlignment="Left" Margin="330,155,0,0" VerticalAlignment="Top" Height="38" Width="160" RenderTransformOrigin="2.435,-3.408"/>
        <PasswordBox x:Name="pswPass" HorizontalAlignment="Left" Margin="50,311,0,0" VerticalAlignment="Top" Width="160" Height="30"/>
        <PasswordBox x:Name="pswPass1" HorizontalAlignment="Left" Margin="50,385,0,0" VerticalAlignment="Top" Width="160" Height="30" PasswordChanged="pswPass1_PasswordChanged"/>
        <TextBox x:Name="txtPhone" HorizontalAlignment="Left" Margin="330,326,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="160" Height="30"/>

    </Grid>
</Page>
